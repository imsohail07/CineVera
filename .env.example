# TMDB API Settings (Get your own key at https://www.themoviedb.org/)
VITE_TMDB_API_KEY=YOUR_TMDB_API_KEY_HERE
VITE_TMDB_API_URL=https://api.themoviedb.org/3
VITE_TMDB_IMG_URL=https://image.tmdb.org/t/p/w500
VITE_TMDB_IMG_ORIGINAL_URL=https://image.tmdb.org/t/p/original

# Streaming Embed Servers (URLs used for iframe player injection)
VITE_STREAM_SERVER_1_MOVIE=https://vidsrc-embed.ru/embed/movie?tmdb=
VITE_STREAM_SERVER_1_TV=https://vidsrc-embed.ru/embed/tv?tmdb=
VITE_STREAM_SERVER_2_MOVIE=https://vidsrc-embed.su/embed/movie/
VITE_STREAM_SERVER_2_TV=https://vidsrc-embed.su/embed/tv/

# Security Lock Configuration
VITE_DEFAULT_PIN=1303

# Desktop Windows App URL (Optional download target)
VITE_WINDOWS_APP_URL=cinevera.com
